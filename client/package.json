{
  "name": "@overlaykit/overlay",
  "version": "0.1.0",
  "description": "Vue 3 client for OverlayKit overlays",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:watch": "vitest --dir tests/unit",
    "test:e2e": "vitest run --dir tests/e2e",
    "type-check": "vue-tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue}\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "pinia": "^2.1.6",
    "vue": "^3.3.6",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/ui": "^4.0.4",
    "@vue/test-utils": "^2.4.1",
    "eslint": "^8.52.0",
    "eslint-plugin-vue": "^9.17.0",
    "happy-dom": "^20.11.0",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.4",
    "vitest": "^4.0.4",
    "vue-tsc": "^3.1.2"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Rodrigo Vicente",
    "url": "https://x.com/rodrigoteamx"
  },
  "private": true
}
