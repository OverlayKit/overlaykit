# OverlayKit — server configuration.
# Copy to server/.env. Every value has a sane default, so the server runs with
# no .env at all; set these only to override.

# Ports
REST_PORT=3000
WS_PORT=8080

# Environment / logging
NODE_ENV=development
LOG_LEVEL=debug                 # debug | info | warn | error

# CORS — comma-separated origins allowed to call the REST API from a browser.
# Leave this COMMENTED to use the built-in dev defaults, which already allow the
# editor (5174), dashboard (5175), panel (5181), landing (5180) and overlay
# (5173). Setting it overrides the defaults, so include every browser origin you
# use (a too-narrow value silently blocks the editor/panel — POST requests fail).
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5180,http://localhost:5181

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: AI design-system generation. Not needed for the MCP design server
# (Claude generates tokens and pushes them); set only if you wire a direct
# server-side generation path.
# ANTHROPIC_API_KEY=sk-ant-...
