# OverlayKit — server configuration.
# Copy to server/.env. Every value has a sane default, so the server runs with
# no .env at all; set these only to override.

# Network. Loopback is the secure default; use a reverse proxy for remote access.
HOST=127.0.0.1
WS_HOST=127.0.0.1
REST_PORT=3000
WS_PORT=8080

# Environment / logging
NODE_ENV=development
LOG_LEVEL=debug                 # debug | info | warn | error

# CORS — comma-separated origins allowed to call the REST API from a browser.
# Leave this COMMENTED to use the built-in dev defaults, which already allow the
# Studio (5173), editor (5174), panel (5181), landing (5180) and overlay
# (5183). Setting it overrides the defaults, so include every browser origin you
# use (a too-narrow value silently blocks the editor/panel — POST requests fail).
# CORS_ORIGIN=http://localhost:5173,http://localhost:5174,http://localhost:5180,http://localhost:5181,http://localhost:5183

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Authentication
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_REQUESTS=10
SESSION_TTL_MS=43200000
COOKIE_SECURE=auto              # auto | always | never

# Device authority. One server process owns this SQLite database exclusively.
# It contains credentials, production evidence, and the private Ed25519 device
# signing identity. Treat the database and every backup as secret material.
# DEVICE_CREDENTIAL_DB=./data/device-credentials.sqlite
# DEVICE_CREDENTIAL_FILE=./data/device-credentials.json  # one-time legacy import only
