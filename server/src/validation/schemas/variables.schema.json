{
  "$id": "https://spec/variables.schema.json",
  "type": "object",
  "patternProperties": {
    "^[a-zA-Z_][a-zA-Z0-9_]*$": { "$ref": "#/$defs/value" }
  },
  "additionalProperties": false,
  "$defs": {
    "value": {
      "anyOf": [
        { "type": ["string", "number", "boolean"] },
        {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/value" }
        }
      ]
    }
  }
}
