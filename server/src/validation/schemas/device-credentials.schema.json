{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "overlaykit-device-credential-store/v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "records"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "records": {
      "type": "array",
      "maxItems": 10000,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "credentialId",
          "label",
          "showId",
          "targets",
          "controlIds",
          "scopes",
          "generation",
          "sealedSecret",
          "issuedBy",
          "issuedAt",
          "updatedAt",
          "expiresAt",
          "revokedAt"
        ],
        "properties": {
          "credentialId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 160,
            "pattern": "^[A-Za-z0-9_-]+$"
          },
          "label": { "type": "string", "minLength": 2, "maxLength": 80 },
          "showId": { "type": "string", "minLength": 1, "maxLength": 200 },
          "targets": {
            "type": "array",
            "minItems": 1,
            "maxItems": 2,
            "uniqueItems": true,
            "items": { "enum": ["preview", "program"] }
          },
          "controlIds": {
            "type": "array",
            "minItems": 1,
            "maxItems": 200,
            "uniqueItems": true,
            "items": { "type": "string", "minLength": 1, "maxLength": 200 }
          },
          "scopes": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "uniqueItems": true,
            "items": {
              "enum": [
                "feedback:read",
                "component.visibility:write",
                "cue:execute",
                "production:take"
              ]
            }
          },
          "generation": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9007199254740991
          },
          "sealedSecret": {
            "type": "string",
            "minLength": 1,
            "maxLength": 4096,
            "not": { "pattern": "^ok_device_" }
          },
          "issuedBy": { "type": "string", "minLength": 1, "maxLength": 200 },
          "issuedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "updatedAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "expiresAt": {
            "type": "integer",
            "minimum": 0,
            "maximum": 9007199254740991
          },
          "revokedAt": {
            "oneOf": [
              { "type": "null" },
              {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              }
            ]
          }
        }
      }
    }
  }
}
