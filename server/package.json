{
  "name": "@overlaykit/server",
  "version": "0.1.0",
  "description": "WebSocket and REST API server for OverlayKit",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "test:unit": "vitest run --dir tests/unit",
    "test:watch": "vitest --dir tests/unit",
    "test:e2e": "vitest run --dir tests/e2e",
    "type-check": "tsc --noEmit",
    "sounds:gen": "node scripts/gen-tones.mjs",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "dependencies": {
    "ajv": "^8.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.8",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "eslint": "^8.52.0",
    "happy-dom": "^20.11.0",
    "prettier": "^3.1.0",
    "supertest": "^7.2.2",
    "tsx": "^4.1.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.4",
    "vitest": "^4.0.4"
  },
  "license": "MIT",
  "private": true
}
