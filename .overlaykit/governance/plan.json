  "rules": [
    {
      "id": "accepted-decisions-are-immutable",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "An accepted decision is never edited or deleted; a successor decision derives supersession."
    },
    {
      "id": "agents-are-delegated",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "An agent identity has no independent project authority and must name its human principal."
    },
    {
      "id": "claims-are-typed",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "Every change separates facts, inferences, assumptions, and unknowns; facts and inferences require evidence."
    },
    {
      "id": "done-is-observed",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "A change is ready only when every enforced gate passed and every enforced artifact is present for the current planHash and manifestHash."
    },
    {
      "id": "evidence-cannot-redefine-law",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "A governance run may report outcomes only for gates and bindings already present in its matching plan and manifest."
    },
    {
      "id": "law-is-compiled",
      "kind": "rule",
      "sourceDecision": "ADR-0001",
      "statement": "Normative governance is the compiled plan derived from accepted immutable decisions and the active profile."
    }
  ],
