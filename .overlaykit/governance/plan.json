  "rules": [
    {
      "id": "accepted-decisions-are-immutable",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "An accepted decision is never edited or deleted; a successor decision derives supersession."
    },
    {
      "id": "accepted-specifications-are-immutable",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "An accepted product specification is never edited or deleted; a successor specification derives supersession."
    },
    {
      "id": "agents-are-delegated",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "An agent identity has no independent project authority and must name its human principal."
    },
    {
      "id": "changes-reference-specifications",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "Version-two architecture, product, security, and documentation changes reference the specifications whose observable criteria authorize their scope."
    },
    {
      "id": "claims-are-typed",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "Every change separates facts, inferences, assumptions, and unknowns; facts and inferences require evidence."
    },
    {
      "id": "credentials-are-purpose-scoped",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "Studio sessions, OBS output tokens, and device tokens are separate, revocable credentials with least-privilege scopes."
    },
    {
      "id": "done-is-observed",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "A change is ready only when every enforced gate passed and every enforced artifact is present for the current planHash and manifestHash."
    },
    {
      "id": "evidence-cannot-redefine-law",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "A governance run may report outcomes only for gates and bindings already present in its matching plan and manifest."
    },
    {
      "id": "hardware-is-an-adapter",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "Hardware and third-party controller support integrates through the vendor-neutral Control API and never defines the core production command model."
    },
    {
      "id": "law-is-compiled",
      "kind": "rule",
      "sourceDecision": "ADR-0003",
      "statement": "Normative governance is the compiled plan derived from accepted immutable decisions, accepted immutable specifications, and the active profile."
    },
    {
      "id": "operator-controls-are-declared",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "A component exposes operator capabilities through typed control definitions rather than inferred variables or arbitrary implementation access."
    },
    {
      "id": "preview-precedes-program",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "The default production workflow prepares Preview and promotes it to Program through an explicit Take command."
    },
    {
      "id": "runtime-does-not-mutate-source",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "Preview and Program state never overwrite a saved Scene or Component Definition without an explicit save-back command."
    },
    {
      "id": "show-is-the-workspace",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "Every saved scene, production session, output, and show-local control belongs to an explicit Show."
    },
    {
      "id": "studio-is-one-shell",
      "kind": "rule",
      "sourceDecision": "ADR-0004",
      "statement": "Authoring, production, library, security, and integrations share one authenticated Studio shell; the headless OBS output remains separate."
    }
  ],
