  "actors": [
    {
      "kind": "human",
      "id": "@rodrigoteamx",
      "principal": null,
      "roles": ["owner", "maintainer", "reviewer"]
    },
    {
      "kind": "agent",
      "id": "codex",
      "principal": "@rodrigoteamx",
      "roles": ["author", "investigator", "producer"]
    },
    {
      "kind": "ci",
      "id": "github-actions",
      "principal": "@rodrigoteamx",
      "roles": ["evidence-producer", "gate-runner"]
    }
  ],
  "assumptions": [
    {
      "id": "bootstrap-authority",
      "statement": "The initial contract is accepted directly by the project owner before external review enforcement exists.",
      "source": "user-directive:2026-07-20"
    },
    {
      "id": "single-maintainer-bootstrap",
      "statement": "The organization currently has one human maintainer available to approve governance changes.",
      "source": "github-org-observation:2026-07-20"
    }
  ],
  "trustAnchors": [
    {
      "kind": "github",
      "id": "github:overlaykit",
      "repository": "OverlayKit/overlaykit",
      "workflowPath": ".github/workflows/governance.yml",
      "jobName": "validate",
      "checkName": "validate",
      "checkAppId": 15368,
      "checkAppSlug": "github-actions",
      "oidcIssuer": "https://token.actions.githubusercontent.com",
      "runnerEnvironment": "github-hosted",
      "protectedRef": "refs/heads/main",
      "ruleset": {
        "name": "main",
        "activationChange": "CHG-0003",
        "requiredRules": [
          "deletion",
          "non_fast_forward",
          "pull_request",
          "required_signatures",
          "required_status_checks"
        ],
        "requiredStatusChecks": ["validate"],
        "allowedMergeMethods": ["merge"],
        "requireReviewThreadResolution": true,
        "dismissStaleReviewsOnPush": false,
        "requireCodeOwnerReview": false,
        "requireLastPushApproval": false,
        "minimumApprovals": 0,
        "strictRequiredStatusChecksPolicy": true,
        "doNotEnforceOnCreate": false,
        "allowBypassActors": false,
        "allowAdditionalRulesets": false,
        "allowAdditionalRules": false
      }
    }
  ]
