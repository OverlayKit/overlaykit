{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "overlaykit-governance-profile/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "version",
    "decisionIds",
    "gates",
    "artifacts",
    "actors",
    "assumptions"
  ],
  "properties": {
    "schemaVersion": { "const": "overlaykit-governance-profile/v1" },
    "name": { "type": "string", "minLength": 1 },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "decisionIds": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "type": "string", "pattern": "^ADR-[0-9]{4}$" }
    },
    "gates": {
      "type": "array",
      "items": { "$ref": "#/$defs/gate" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifact" }
    },
    "actors": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/actor" }
    },
    "assumptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/assumption" }
    }
  },
  "$defs": {
    "tier": {
      "enum": ["enforced", "advisory", "convention", "deferred"]
    },
    "nullableString": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "gate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "tier", "boundTo"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tier": { "$ref": "#/$defs/tier" },
        "boundTo": { "$ref": "#/$defs/nullableString" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "description", "tier", "producedBy"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "tier": { "$ref": "#/$defs/tier" },
        "producedBy": { "$ref": "#/$defs/nullableString" }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "principal", "roles"],
      "properties": {
        "kind": { "enum": ["human", "agent", "ci", "service"] },
        "id": { "type": "string", "minLength": 1 },
        "principal": { "$ref": "#/$defs/nullableString" },
        "roles": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    }
  }
}
