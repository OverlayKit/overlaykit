{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "overlaykit-governance-run/v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "runId",
    "profileHash",
    "planHash",
    "manifestHash",
    "invokedBy",
    "producer",
    "source",
    "startedAt",
    "finishedAt",
    "assumptions",
    "outcomes",
    "artifacts"
  ],
  "properties": {
    "schemaVersion": { "const": "overlaykit-governance-run/v1" },
    "runId": { "type": "string", "minLength": 1 },
    "profileHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "planHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "manifestHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "invokedBy": { "$ref": "#/$defs/invocation" },
    "producer": { "$ref": "#/$defs/producer" },
    "source": { "type": "string", "minLength": 1 },
    "startedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "finishedAt": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T"
    },
    "assumptions": {
      "type": "array",
      "items": { "$ref": "#/$defs/assumption" }
    },
    "outcomes": {
      "type": "array",
      "items": { "$ref": "#/$defs/outcome" }
    },
    "artifacts": {
      "type": "array",
      "items": { "$ref": "#/$defs/artifactEvidence" }
    }
  },
  "$defs": {
    "nullableString": {
      "oneOf": [{ "type": "null" }, { "type": "string", "minLength": 1 }]
    },
    "invocation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "principal"],
      "properties": {
        "kind": { "enum": ["human", "agent", "ci", "service"] },
        "id": { "type": "string", "minLength": 1 },
        "principal": { "$ref": "#/$defs/nullableString" }
      }
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "id", "version", "commit"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": "string", "minLength": 1 },
        "version": { "$ref": "#/$defs/nullableString" },
        "commit": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[a-fA-F0-9]{7,64}$" }
          ]
        }
      }
    },
    "assumption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "statement", "source"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "statement": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "outcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "gate",
        "outcome",
        "producerRef",
        "justification",
        "boundTo"
      ],
      "properties": {
        "gate": { "type": "string", "minLength": 1 },
        "outcome": { "enum": ["passed", "failed", "waived", "pending"] },
        "producerRef": { "$ref": "#/$defs/nullableString" },
        "justification": { "$ref": "#/$defs/nullableString" },
        "boundTo": { "$ref": "#/$defs/nullableString" }
      }
    },
    "artifactEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact", "producerRef", "contentHash"],
      "properties": {
        "artifact": { "type": "string", "minLength": 1 },
        "producerRef": { "type": "string", "minLength": 1 },
        "contentHash": {
          "oneOf": [
            { "type": "null" },
            { "type": "string", "pattern": "^[a-f0-9]{64}$" }
          ]
        }
      }
    }
  }
}
